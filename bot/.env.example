# backend/.env dagi bilan BIR XIL bo'lishi shart (bir xil bot, bir xil baza)
BOT_TOKEN=
DATABASE_URL=

# Mini App havolasi — /start xabaridagi "Ilovani ochish" tugmasi shunga olib boradi
MINIAPP_URL=https://t.me/your_bot/app

# Eslatmalar (reminders.py) qancha soatda bir marta tekshirilsin
REMINDER_INTERVAL_HOURS=1
