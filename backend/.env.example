# BotFather bergan token (masalan 123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
BOT_TOKEN=

# JWT tokenlarni imzolash uchun tasodifiy uzun matn (masalan: openssl rand -hex 32)
JWT_SECRET=

# Admin bo'ladigan Telegram user ID'lar, vergul bilan ajratilgan
# Telegram ID'ingizni bilish uchun @userinfobot ga /start yozing
# Masalan: ADMIN_TELEGRAM_IDS=5842067106
ADMIN_TELEGRAM_IDS=

# PostgreSQL manzili — lokal ishga tushirishda docker-compose shu qiymatni beradi
DATABASE_URL="postgresql://tezprava:tezprava@localhost:5432/tezprava?schema=public"

PORT=3001
