// Prisma sxemasi — bitta fayl orqali butun DB tuzilmasini boshqaradi.
// Serverni ko'chirishda kerak bo'ladigani: shu fayl + migrations/ papkasi.
// Yangi serverda: DATABASE_URL ni sozlab, `npx prisma migrate deploy` ni ishga tushirish kifoya.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AttemptType {
  TICKET
  EXAM
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum SenderType {
  USER
  ADMIN
}

// PENDING — OCR bosqichidan o'tdi (ogohlantirish bilan yoki yo'q), admin tekshiruvini kutmoqda.
// Faollashtirish HAR DOIM admin tasdig'i orqali — OCR hech qachon o'zi APPROVED qilmaydi.
enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  SUPPORT_MESSAGE
  PAYMENT_REQUEST
  PREMIUM_EXPIRING
  NEW_REGISTRATION
}

// User Profile'dagi vertikal timeline shu turlardan quriladi
enum ActivityType {
  REGISTERED
  TEST_COMPLETED
  PREMIUM_GRANTED
  PREMIUM_EXTENDED
  PREMIUM_EXPIRED
  DISCOUNT_GRANTED
  PAYMENT_SUBMITTED
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  SUPPORT_MESSAGE
  BLOCKED
  UNBLOCKED
  MADE_ADMIN
  REMOVED_ADMIN
  REFERRAL_JOINED
  REFERRAL_REWARD_GIVEN
  SCHOOL_CREATED
  SCHOOL_JOINED
  SCHOOL_APPROVED
  SCHOOL_DISABLED
  SCHOOL_DELETED
}

// Har bir admin amali shu yerga yoziladi — kim, nimani, kimga qildi
enum AdminLogAction {
  PREMIUM_GRANTED
  PREMIUM_REMOVED
  PREMIUM_EXTENDED
  DISCOUNT_GRANTED
  DISCOUNT_REMOVED
  USER_BLOCKED
  USER_UNBLOCKED
  ADMIN_GRANTED
  ADMIN_REMOVED
  ACCOUNT_DELETED
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  SUPPORT_REPLIED
  SUPPORT_CLOSED
  SUPPORT_REOPENED
  BROADCAST_SENT
  PAYMENT_SETTINGS_UPDATED
}

enum BroadcastAudience {
  ALL
  PREMIUM
  VIP
  BLOCKED
  SELECTED
}

model User {
  id            Int      @id @default(autoincrement())
  telegramId    BigInt   @unique @map("telegram_id")
  name          String
  username      String?
  phone         String?
  role          Role     @default(USER)
  isPremium     Boolean  @default(false) @map("is_premium")
  premiumPlan   String?   @map("premium_plan")
  premiumStartedAt DateTime? @map("premium_started_at")
  premiumExpiresAt DateTime? @map("premium_expires_at")
  examReadiness Int      @default(0) @map("exam_readiness")
  isBlocked     Boolean  @default(false) @map("is_blocked")
  blockedReason String?  @map("blocked_reason")
  lastOnlineAt  DateTime? @map("last_online_at")
  avatarUrl     String?  @map("avatar_url")
  adminNotes    String?  @map("admin_notes") // faqat adminlarga ko'rinadi, foydalanuvchiga ko'rsatilmaydi
  referralCode  String?  @unique @map("referral_code") // shu foydalanuvchining o'z taklif kodi
  examDate      DateTime? @map("exam_date") // onboarding'da kiritiladi — "Exam Soon" filtri shundan foydalanadi
  age           Int?     @map("age") // ro'yxatdan o'tish formasida kiritiladi — statistika uchun
  dailyStudyMinutes Int? @map("daily_study_minutes") // ro'yxatdan o'tish formasida kiritiladi — kuniga qancha shug'ullanishni rejalashtiradi
  registrationCompletedAt DateTime? @map("registration_completed_at") // profil so'rovnomasi to'ldirilgan payt
  referredById  Int?     @map("referred_by_id") // kim uni taklif qilgan (agar mavjud bo'lsa)
  // Ommaviy reytingda (leaderboard) ko'rinishni xohlaydimi. Sozlamalardan
  // o'chirilsa, foydalanuvchi barcha ommaviy reytinglardan butunlay chiqariladi.
  showOnLeaderboard Boolean @default(true) @map("show_on_leaderboard")
  referredBy    User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("Referrals") // shu foydalanuvchi taklif qilgan barcha odamlar
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  attempts      Attempt[]

  conversation      Conversation?
  paymentRequests    PaymentRequest[]
  discount           Discount?
  activities          ActivityLog[]
  adminActionsTaken   AdminLog[] @relation("AdminActor")
  notifications       Notification[]
  examAttempts        ExamAttempt[]
  schoolMemberships   Membership[]
  ownedSchools        School[]   @relation("SchoolOwner")

  @@map("users")
  @@index([isPremium])
  @@index([isBlocked])
  @@index([referredById])
}

// Har bir yakunlangan bilet testi yoki imtihon urinishi shu yerga yoziladi.
// Statistika (aniqlik, streak, imtihonga tayyorgarlik) shu jadvaldan hisoblanadi.
model Attempt {
  id           Int         @id @default(autoincrement())
  userId       Int         @map("user_id")
  user         User        @relation(fields: [userId], references: [id])
  type         AttemptType
  ticketNumber Int?        @map("ticket_number") // TICKET uchun bilet raqami, EXAM uchun null
  correctCount Int         @map("correct_count")
  totalCount   Int         @map("total_count")
  passed       Boolean
  createdAt    DateTime    @default(now()) @map("created_at")

  @@map("attempts")
  @@index([userId])
  @@index([userId, createdAt])
}

// Har bir foydalanuvchi bittagina suhbat "tredi"ga ega (real vaqt chat kabi),
// ichida ko'p SupportMessage bo'ladi — ro'yxat va qidiruv shu orqali sodda bo'ladi.
model Conversation {
  id             Int                @id @default(autoincrement())
  userId         Int                @unique @map("user_id")
  user           User               @relation(fields: [userId], references: [id])
  status         ConversationStatus @default(OPEN)
  unreadForAdmin Int                @default(0) @map("unread_for_admin")
  unreadForUser  Int                @default(0) @map("unread_for_user")
  lastMessageAt  DateTime?          @map("last_message_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  messages       SupportMessage[]

  @@map("conversations")
  @@index([status, lastMessageAt])
}

model SupportMessage {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         SenderType
  text           String?
  imageUrl       String?      @map("image_url")
  isRead         Boolean      @default(false) @map("is_read")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("support_messages")
  @@index([conversationId, createdAt])
}

// Har bir chek yuklash shu yerga yoziladi. OCR ma'lumotlari saqlanadi va
// admin ko'rib chiqishini tezlashtiradi, lekin ular hech qachon avtomatik
// tasdiqlashga olib kelmaydi — status har doim admin qarori bilan o'zgaradi.
model PaymentRequest {
  id              Int           @id @default(autoincrement())
  userId          Int           @map("user_id")
  user            User          @relation(fields: [userId], references: [id])
  planKey         String        @map("plan_key")
  planName        String        @map("plan_name")
  amount          Int
  originalAmount  Int           @map("original_amount")
  discountPercent Int           @default(0) @map("discount_percent")
  receiptImageUrl String        @map("receipt_image_url")
  receiptHash     String        @map("receipt_hash")
  status          PaymentStatus @default(PENDING)

  ocrExtractedText   String?   @map("ocr_extracted_text")
  ocrExtractedAmount Int?      @map("ocr_extracted_amount")
  ocrExtractedCard   String?   @map("ocr_extracted_card")
  ocrExtractedDate   DateTime? @map("ocr_extracted_date")
  ocrWarnings        String?   @map("ocr_warnings")
  ocrConfidence      Int?      @map("ocr_confidence")

  rejectionReason String?   @map("rejection_reason")
  reviewedById    Int?      @map("reviewed_by_id")
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("payment_requests")
  @@index([status, ocrConfidence])
  @@index([receiptHash])
  @@index([userId])
}

model Discount {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  percent   Int
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("discounts")
}

model ActivityLog {
  id        Int          @id @default(autoincrement())
  userId    Int          @map("user_id")
  user      User         @relation(fields: [userId], references: [id])
  type      ActivityType
  message   String
  metadata  String?
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("activity_logs")
  @@index([userId, createdAt])
}

model AdminLog {
  id           Int            @id @default(autoincrement())
  actorId      Int            @map("actor_id")
  actor        User           @relation("AdminActor", fields: [actorId], references: [id])
  action       AdminLogAction
  targetUserId Int?           @map("target_user_id")
  targetLabel  String?        @map("target_label")
  details      String?
  createdAt    DateTime       @default(now()) @map("created_at")

  @@map("admin_logs")
  @@index([createdAt])
  @@index([actorId])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String?
  isRead    Boolean          @default(false) @map("is_read")
  linkType  String?          @map("link_type")
  linkId    Int?             @map("link_id")
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("notifications")
  @@index([userId, isRead])
}

model BroadcastMessage {
  id        Int               @id @default(autoincrement())
  text      String
  audience  BroadcastAudience
  sentCount Int               @default(0) @map("sent_count")
  createdAt DateTime          @default(now()) @map("created_at")

  @@map("broadcast_messages")
}

// Foydalanuvchiga to'lov ekranida ko'rsatiladigan karta ma'lumotlari.
// Bitta qatordan iborat (id har doim 1) — admin panel orqali o'zgartiriladi,
// .env'ga bog'liq emas, deploy qilmasdan yangilanadi. OCR ham shu jadvaldagi
// karta raqami bilan solishtiradi (payments.js orqali).
model PaymentSettings {
  id           Int      @id @default(1)
  cardNumber   String   @map("card_number")
  cardOwner    String   @map("card_owner")
  updatedById  Int?     @map("updated_by_id")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("payment_settings")
}

// ============================================================================
// RASMIY IMTIHON (Official Exam)
//
// Mashq imtihonidan (ExamScreen.jsx, Attempt jadvali) BUTUNLAY ALOHIDA.
// Mashq imtihoni: 25 daqiqa, 2 xatoda tugaydi, natija Attempt'ga yoziladi.
// Rasmiy imtihon: 20 daqiqa, 18/20 kerak, erkin navigatsiya, natija shu yerda.
//
// ASOSIY XAVFSIZLIK QARORI: savollar va to'g'ri javoblar HECH QACHON
// frontendga to'liq yuborilmaydi. Frontend faqat savol matni va variantlarni
// oladi; baholash faqat serverda, submit paytida bo'ladi. Aks holda har kim
// DevTools orqali javoblarni ko'rib, reyting va statistikani ma'nosiz
// qilib qo'yardi.
// ============================================================================

enum ExamStatus {
  IN_PROGRESS // boshlangan, hali yakunlanmagan (ilova yopilsa shu holatda qoladi)
  COMPLETED   // yakunlangan (qo'lda yuborilgan yoki vaqti tugab avtomatik yopilgan)
  ABANDONED   // foydalanuvchi ataylab bekor qilgan
}

// Imtihon hayotiy siklidagi hodisalar — kelajakdagi analitika va qo'llab-quvvatlash
// uchun. Masalan: "foydalanuvchi imtihonni 5 marta tark etgan" yoki
// "imtihon vaqti tugab avtomatik yopilgan" kabi savollarga javob beradi.
enum ExamEventType {
  CREATED
  RESUMED
  FOCUS_LOST
  SUBMITTED
  EXPIRED
  ABANDONED
}

model ExamAttempt {
  id     Int        @id @default(autoincrement())
  userId Int        @map("user_id")
  user   User       @relation(fields: [userId], references: [id])
  status ExamStatus @default(IN_PROGRESS)

  // Imtihon qoidalari versiyasi. Kelajakda qoidalar o'zgarsa (masalan
  // savollar soni yoki o'tish balli), eski imtihonlar o'z versiyasi bo'yicha
  // to'g'ri talqin qilinadi va statistika buzilmaydi.
  examVersion Int @default(1) @map("exam_version")

  // Savollar TASODIFIY tanlanadi, lekin seed serverda saqlanadi — shuning
  // uchun tugallanmagan imtihon tiklanganda AYNAN o'sha savollar qaytadi.
  // questionIds ham saqlanadi (savol bazasi kelajakda o'zgarsa, eski
  // imtihonni baribir to'g'ri ko'rsatish uchun).
  questionSeed Int    @map("question_seed")
  questionIds  String @map("question_ids") // JSON massiv: ["t1-3","t7-12",...]

  // Foydalanuvchi javoblari. JSON obyekt: {"0":2,"3":1} — kalit savol indeksi,
  // qiymat tanlangan variant indeksi. Javob berilmagan savol umuman bo'lmaydi.
  answers String @default("{}")

  startedAt   DateTime  @default(now()) @map("started_at")
  expiresAt   DateTime  @map("expires_at") // startedAt + imtihon davomiyligi
  finishedAt  DateTime? @map("finished_at")
  durationSec Int?      @map("duration_sec")

  correctCount   Int?     @map("correct_count")
  wrongCount     Int?     @map("wrong_count")
  accuracyPct    Int?     @map("accuracy_pct")
  passed         Boolean?
  // Foydalanuvchi imtihon paytida ilovadan necha marta chiqqani.
  // ESLATMA: bu faqat KO'RSATKICH, ishonchli anti-cheat emas — frontend
  // yuboradi, ya'ni texnik bilimi bor foydalanuvchi buni to'sib qo'yishi mumkin.
  focusLostCount Int      @default(0) @map("focus_lost_count")

  events ExamEvent[]

  @@map("exam_attempts")
  @@index([userId, status])
  @@index([userId, startedAt])
  // Leaderboard so'rovlari uchun: yakunlangan, o'tgan imtihonlarni
  // ball/vaqt bo'yicha tartiblash
  @@index([status, passed, correctCount])
  @@index([status, finishedAt])
}

model ExamEvent {
  id            Int           @id @default(autoincrement())
  examAttemptId Int           @map("exam_attempt_id")
  examAttempt   ExamAttempt   @relation(fields: [examAttemptId], references: [id], onDelete: Cascade)
  type          ExamEventType
  metadata      String?
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("exam_events")
  @@index([examAttemptId, createdAt])
}

// ============================================================================
// HAYDOVCHILIK MAKTABLARI EKOTIZIMI (Driving School Ecosystem)
//
// To'rt ishtirokchi: CEO (platforma egasi — mavjud Role.ADMIN dan foydalanadi),
// Maktab egasi (OWNER), O'qituvchi (TEACHER), Talaba (STUDENT).
//
// MUHIM ARXITEKTURA QARORI: maktab ichidagi rol (OWNER/TEACHER/STUDENT)
// GLOBAL User.role dan ALOHIDA — Membership jadvalida saqlanadi. Sabab:
// global rol butun platformaga tegishli (USER/ADMIN), maktab ichidagi rol
// esa faqat shu maktabga tegishli kontekst. Bu ikkalasini aralashtirmaslik
// kelajakda (masalan) bitta odam turli kontekstda turli maktab-rolga ega
// bo'lish stsenariylarini soddalashtiradi va global auth tizimiga tegmaydi.
//
// Bitta foydalanuvchi bir vaqtning o'zida faqat BITTA faol (ACTIVE)
// a'zolikka ega bo'lishi mumkin — buni DB darajasida qisman himoya qiladi
// (@@unique([userId, status]) FAQAT ACTIVE uchun emas, shuning uchun bu
// qoida service qatlamida — schoolService.js da — kafolatlanadi, lekin
// bir nechta ACTIVE yozuv paydo bo'lmasligi uchun partial unique index
// migratsiya faylida qo'lda qo'shiladi).
// ============================================================================

enum SchoolStatus {
  PENDING   // yaratilgan, CEO tasdig'ini kutmoqda
  ACTIVE    // ishlayapti
  DISABLED  // CEO tomonidan to'xtatilgan (talabalar/o'qituvchilar kira olmaydi)
}

enum SchoolMemberRole {
  OWNER
  TEACHER
  STUDENT
}

enum MembershipStatus {
  ACTIVE     // joriy, faol a'zolik
  ARCHIVED   // talaba boshqa maktabga o'tgani uchun yopilgan
  SUSPENDED  // o'qituvchi vaqtincha to'xtatilgan (Owner tomonidan)
  REMOVED    // Owner/CEO tomonidan olib tashlangan
}

enum InvitationType {
  SCHOOL // maktabga umumiy taklif (guruh keyinroq tayinlanadi)
  GROUP  // to'g'ridan-to'g'ri muayyan guruhga
}

enum HomeworkType {
  PRACTICE       // mashq imtihoni (istalgan mavzu)
  OFFICIAL_EXAM  // rasmiy imtihon (ExamAttempt orqali kuzatiladi)
  TICKETS        // muayyan biletlar ro'yxati
  SIGNS          // yo'l belgilari bo'yicha
}

enum HomeworkSubmissionStatus {
  PENDING     // muddat hali tugamagan, hali bajarilmagan
  COMPLETED   // muddatida bajarilgan
  LATE        // muddatdan keyin bajarilgan
  MISSED      // muddat tugagan, bajarilmagan (lazy — cron kerak emas)
}

model School {
  id        Int          @id @default(autoincrement())
  name      String
  logoUrl   String?      @map("logo_url")
  brandColor String?     @map("brand_color") // hex, masalan "#0EA5E9"
  address   String?
  phone     String?
  status    SchoolStatus @default(PENDING)

  ownerId   Int?         @map("owner_id") // qulaylik uchun keshlangan — asosiy manba Membership(role=OWNER)
  owner     User?        @relation("SchoolOwner", fields: [ownerId], references: [id])

  createdById Int?       @map("created_by_id") // maktabni yaratgan CEO/admin
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  disabledReason String? @map("disabled_reason")
  disabledAt     DateTime? @map("disabled_at")

  groups      Group[]
  memberships Membership[]
  invitations Invitation[]
  homeworks   Homework[]

  @@map("schools")
  @@index([status])
}

model Group {
  id        Int      @id @default(autoincrement())
  schoolId  Int      @map("school_id")
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String   // "Ertalabki", "Kechki", "VIP" va h.k. — erkin matn
  createdAt DateTime @default(now()) @map("created_at")

  memberships Membership[]
  invitations Invitation[]
  homeworks   Homework[]

  @@map("school_groups")
  @@index([schoolId])
}

// Foydalanuvchi <-> Maktab bog'lanishi. Rol shu yerda saqlanadi.
model Membership {
  id       Int               @id @default(autoincrement())
  userId   Int               @map("user_id")
  user     User              @relation(fields: [userId], references: [id])
  schoolId Int               @map("school_id")
  school   School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  groupId  Int?              @map("group_id") // talaba/o'qituvchi qaysi guruhda; Owner uchun null
  group    Group?            @relation(fields: [groupId], references: [id])

  role     SchoolMemberRole
  status   MembershipStatus  @default(ACTIVE)

  joinedAt DateTime          @default(now()) @map("joined_at")
  endedAt  DateTime?         @map("ended_at") // ARCHIVED/REMOVED bo'lgan payt

  homeworkSubmissions HomeworkSubmission[]

  @@map("school_memberships")
  @@index([userId, status])
  @@index([schoolId, role, status])
  @@index([groupId, status])
}

model Invitation {
  id        Int             @id @default(autoincrement())
  code      String          @unique // qisqa, o'qish oson kod (masalan "AVTO-7F2K")
  type      InvitationType
  schoolId  Int             @map("school_id")
  school    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  groupId   Int?            @map("group_id")
  group     Group?          @relation(fields: [groupId], references: [id])

  createdById Int           @map("created_by_id")
  maxUses     Int?          @map("max_uses") // null = cheksiz
  usedCount   Int           @default(0) @map("used_count")
  expiresAt   DateTime?     @map("expires_at")
  revokedAt   DateTime?     @map("revoked_at")

  createdAt DateTime        @default(now()) @map("created_at")

  @@map("school_invitations")
  @@index([schoolId])
  @@index([code])
}

model Homework {
  id       Int          @id @default(autoincrement())
  schoolId Int          @map("school_id")
  school   School       @relation(fiel